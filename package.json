{
  "name": "htmly",
  "displayName": "Htmly",
  "description": "A WYSIWYG HTML editor for VSCode — edit visually or in source, always synced",
  "version": "1.8.6",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/jinshan/htmly.git"
  },
  "publisher": "jinshan",
  "engines": {
    "vscode": "^1.80.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onCustomEditor:htmly.editor"
  ],
  "main": "./dist/extension/index.js",
  "contributes": {
    "commands": [
      {
        "command": "htmly.toggleMode",
        "title": "Htmly: Toggle Edit Mode",
        "icon": "$(refresh)"
      },
      {
        "command": "htmly.setMode.wysiwyg",
        "title": "Htmly: Switch to WYSIWYG Mode"
      },
      {
        "command": "htmly.setMode.source",
        "title": "Htmly: Switch to Source Mode"
      },
      {
        "command": "htmly.setMode.preview",
        "title": "Htmly: Switch to Preview Mode"
      },
      {
        "command": "htmly.setMode.split",
        "title": "Htmly: Switch to Split Mode"
      },
      {
        "command": "htmly.save",
        "title": "Htmly: Save File (Bypass Debounce)"
      },
      {
        "command": "htmly.searchProject",
        "title": "Htmly: Project-Wide Search"
      },
      {
        "command": "htmly.openKeybindingManager",
        "title": "Htmly: Open Keybinding Manager"
      },
      {
        "command": "htmly.exportKeybindings",
        "title": "Htmly: Export Keybindings"
      },
      {
        "command": "htmly.importKeybindings",
        "title": "Htmly: Import Keybindings"
      }
    ],
    "keybindings": [
      {
        "command": "htmly.save",
        "key": "ctrl+s",
        "mac": "cmd+s",
        "when": "activeCustomEditorId == htmly.editor"
      },
      {
        "command": "htmly.searchProject",
        "key": "ctrl+shift+f",
        "mac": "cmd+shift+f",
        "when": "activeCustomEditorId == htmly.editor"
      }
    ],
    "menus": {
      "editor/title": [
        {
          "command": "htmly.toggleMode",
          "when": "activeCustomEditorId == htmly.editor",
          "group": "navigation"
        }
      ]
    },
    "configuration": {
      "title": "Htmly",
      "properties": {
        "htmly.defaultMode": {
          "type": "string",
          "enum": [
            "wysiwyg",
            "source",
            "preview",
            "split"
          ],
          "default": "wysiwyg",
          "description": "Default editor mode when opening a file"
        },
        "htmly.showButtonLabels": {
          "type": "boolean",
          "default": true,
          "description": "Show text labels below toolbar buttons"
        },
        "htmly.autoHideToolbarInPreview": {
          "type": "boolean",
          "default": true,
          "description": "Hide toolbar when in Preview mode"
        },
        "htmly.defaultFontSize": {
          "type": "number",
          "default": 14,
          "description": "Default font size for the editor"
        },
        "htmly.enableMarkdownShortcuts": {
          "type": "boolean",
          "default": true,
          "description": "Enable markdown shortcuts (e.g., # for headings, ** for bold)"
        },
        "htmly.splitScreenDirection": {
          "type": "string",
          "enum": [
            "horizontal",
            "vertical"
          ],
          "default": "horizontal",
          "description": "Direction of the split screen (horizontal: left-right, vertical: top-bottom)"
        },
        "htmly.customTheme.primaryColor": {
          "type": "string",
          "default": "#0e639c",
          "description": "Primary accent color for the editor theme"
        },
        "htmly.useAsDefaultEditor": {
          "type": "boolean",
          "default": false,
          "description": "Use Htmly Editor as the default editor for HTML files (requires restart or re-open of existing files)"
        },
        "htmly.cloudStorage.provider": {
          "type": "string",
          "enum": [
            "none",
            "s3",
            "cloudinary",
            "imgbb"
          ],
          "default": "none",
          "description": "Cloud storage provider for image uploads. Use 'none' for base64 encoding."
        },
        "htmly.cloudStorage.s3.accessKeyId": {
          "type": "string",
          "default": "",
          "description": "AWS S3 Access Key ID"
        },
        "htmly.cloudStorage.s3.secretAccessKey": {
          "type": "string",
          "default": "",
          "description": "AWS S3 Secret Access Key"
        },
        "htmly.cloudStorage.s3.bucket": {
          "type": "string",
          "default": "",
          "description": "S3 bucket name"
        },
        "htmly.cloudStorage.s3.region": {
          "type": "string",
          "default": "us-east-1",
          "description": "AWS region (e.g., us-east-1, eu-west-1)"
        },
        "htmly.cloudStorage.cloudinary.apiKey": {
          "type": "string",
          "default": "",
          "description": "Cloudinary API Key"
        },
        "htmly.cloudStorage.cloudinary.apiSecret": {
          "type": "string",
          "default": "",
          "description": "Cloudinary API Secret"
        },
        "htmly.cloudStorage.cloudinary.cloudName": {
          "type": "string",
          "default": "",
          "description": "Cloudinary Cloud Name"
        },
        "htmly.cloudStorage.imgbb.apiKey": {
          "type": "string",
          "default": "",
          "description": "ImgBB API Key"
        },
        "htmly.spellCheck.enabled": {
          "type": "boolean",
          "default": true,
          "description": "Enable spell checking in the editor"
        },
        "htmly.spellCheck.customDictionary": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "default": [],
          "description": "Custom dictionary words to ignore (added via 'Add to Dictionary' action)"
        },
        "htmly.keybindings.overrides": {
          "type": "object",
          "default": {},
          "description": "Override default keybindings for Htmly commands. Format: { \"commandId\": { \"key\": \"ctrl+b\", \"mac\": \"cmd+b\", \"when\": \"...\" } }",
          "patternProperties": {
            "^htmly\\.": {
              "type": "object",
              "properties": {
                "command": {
                  "type": "string"
                },
                "key": {
                  "type": "string"
                },
                "mac": {
                  "type": "string"
                },
                "when": {
                  "type": "string"
                }
              },
              "additionalProperties": false
            }
          }
        },
        "htmly.debug": {
          "type": "boolean",
          "default": true,
          "description": "Enable diagnostic logging from the Htmly webview/editor. When enabled, webview console output is forwarded to the 'htmly-debug' Output Channel (View → Output → htmly-debug). Set to false to silence logs in production."
        }
      }
    },
    "customEditors": [
      {
        "viewType": "htmly.editor",
        "displayName": "Htmly Editor",
        "selector": [
          {
            "filenamePattern": "*.html"
          },
          {
            "filenamePattern": "*.htm"
          }
        ],
        "priority": "default"
      }
    ],
    "languages": [
      {
        "id": "htmly-content",
        "aliases": [
          "Htmly Content"
        ],
        "extensions": [],
        "configuration": "./language-config.json"
      }
    ]
  },
  "scripts": {
    "vscode:prepublish": "npm run build",
    "build": "npm run build:extension && npm run build:webview",
    "build:extension": "esbuild ./src/extension/index.ts --bundle --outfile=dist/extension/index.js --external:vscode --format=cjs --platform=node --minify && cp node_modules/sql.js/dist/sql-wasm.wasm dist/extension/",
    "build:webview": "cd webview && npm run build",
    "dev:extension": "esbuild ./src/extension/index.ts --bundle --outfile=dist/extension/index.js --external:vscode --format=cjs --platform=node --watch",
    "dev:webview": "cd webview && npm run dev",
    "test": "npm run test:e2e",
    "test:e2e": "npm run build && npm run test:e2e:compile && node ./test/e2e/runTest.js",
    "test:e2e:compile": "esbuild ./test/e2e/suite/index.ts --bundle --outfile=dist/test/e2e/suite/index.js --external:vscode --format=cjs --platform=node",
    "lint": "eslint src --ext .ts",
    "preview": "node ./scripts/preview-e2e.js",
    "package": "node ./scripts/package-vsix.js",
    "package:raw": "vsce package"
  },
  "devDependencies": {
    "@types/mocha": "^10.0.10",
    "@types/node": "^20.10.0",
    "@types/pdfmake": "^0.3.2",
    "@types/vscode": "^1.80.0",
    "@typescript-eslint/eslint-plugin": "^6.13.0",
    "@typescript-eslint/parser": "^6.13.0",
    "@vscode/test-electron": "^2.5.2",
    "@vscode/vsce": "^2.22.0",
    "esbuild": "^0.19.8",
    "eslint": "^8.55.0",
    "mocha": "^11.7.5",
    "typescript": "^5.3.2",
    "vitest": "^1.0.4"
  },
  "dependencies": {
    "docx": "^9.6.1",
    "pdfmake": "^0.3.8",
    "sql.js": "^1.14.1"
  }
}
